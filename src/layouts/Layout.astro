---
import "../styles/global.css";
import { Preloader } from "../components/loader/Preloader";
import { Navbar } from "../components/navbar/Navbar";
import { CustomCursor } from "../components/cursor/CustomCursor";

interface Props {
  title: string;
  description?: string | null;
  canonicalUrl?: string | null;
  ogImageUrl?: string | null;
}

const {
  title,
  description = "Aahad's Portfolio",
  canonicalUrl,
  ogImageUrl,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description || "Aahad's Portfolio"} />
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link
      href="https://api.fontshare.com/v2/css?f[]=general-sans@300,400,500,600,700&f[]=clash-display@400,500,600,700&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
    <script is:inline>
      (function () {
        var DARK = ["mono-dark", "orange"];
        var VALID = ["mono-dark", "mono-light", "orange", "orange-light"];
        var BG = { "orange": "#0a0a0a", "orange-light": "#faf5f0", "mono-dark": "#0a0a0a", "mono-light": "#fafafa" };
        var stored = localStorage.getItem("theme");
        var theme = VALID.indexOf(stored) !== -1 ? stored : "orange";
        document.documentElement.setAttribute("data-theme", theme);
        document.documentElement.classList.toggle("dark", DARK.indexOf(theme) !== -1);
        document.documentElement.style.backgroundColor = BG[theme] || "#0a0a0a";
      })();
    </script>
  </head>
  <body class="min-h-screen">
    <Preloader client:load />
    <CustomCursor client:load />
    <Navbar client:load />
    <slot />
  </body>
</html>
